{
  "name": "arcsub",
  "private": true,
  "version": "0.9.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "dev:dryrun": "powershell -ExecutionPolicy Bypass -File ./start.ps1 -DryRun",
    "dev:clean:linux": "bash ./start.sh",
    "dev:dryrun:linux": "bash ./start.sh --dry-run",
    "dev:windows": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "dev:linux": "bash ./start.sh",
    "deploy:windows": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1",
    "deploy:linux": "bash ./deploy.sh",
    "start:prod:windows": "powershell -ExecutionPolicy Bypass -File ./start.production.ps1",
    "start:prod:linux": "bash ./start.production.sh",
    "build": "npm run -s build:client",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json && node ./scripts/copy-server-runtime-assets.mjs",
    "build:prod": "npm run -s build:client && npm run -s build:server",
    "archive:windows": "node ./scripts/archive-release.mjs windows-x64",
    "archive:linux": "node ./scripts/archive-release.mjs linux-x64",
    "archive:release": "node ./scripts/archive-release.mjs all",
    "package:linux": "npm run -s build:prod && node ./scripts/package-linux-release.mjs",
    "package:linux:archive": "npm run -s package:linux && npm run -s archive:linux",
    "package:windows": "npm run -s build:prod && node ./scripts/package-windows-release.mjs",
    "package:windows:archive": "npm run -s package:windows && npm run -s archive:windows",
    "package:release": "npm run -s build:prod && node ./scripts/package-release.mjs",
    "package:release:archive": "npm run -s package:release && npm run -s archive:release",
    "package:all:archive": "npm run -s package:windows:archive && npm run -s package:linux:archive",
    "release:checksums": "node ./scripts/generate-release-checksums.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\"",
    "clean:runtime:dry": "tsx scripts/clean-runtime.ts",
    "clean:runtime": "tsx scripts/clean-runtime.ts --apply",
    "typecheck": "tsc --noEmit",
    "test:asr-source": "tsx scripts/asr-source-guard.ts",
    "test:asr-local": "tsx scripts/asr-local-smoke.ts",
    "test:asr-providers": "tsx scripts/asr-provider-tests.ts",
    "test:cloud-translation": "tsx scripts/cloud-translation-orchestrator-smoke.ts",
    "check": "npm run -s typecheck && npm run -s build",
    "lint": "npm run -s typecheck"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@huggingface/transformers": "^4.0.1",
    "@pinyin-pro/data": "^1.3.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/fs-extra": "^11.0.4",
    "@types/kuromoji": "^0.1.3",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.0.4",
    "artplayer": "^5.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fs-extra": "^11.3.4",
    "hangul-romanization": "^1.0.1",
    "kuromoji": "^0.1.2",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "onnxruntime-node": "^1.24.3",
    "opencc-js": "^1.0.5",
    "openvino-genai-node": "^2026.1.0",
    "openvino-node": "^2026.1.0",
    "pinyin-pro": "^3.28.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sherpa-onnx": "^1.12.37",
    "unzipper": "^0.12.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
