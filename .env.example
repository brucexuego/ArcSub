# Copy this file to `.env` for local runtime
# PowerShell: Copy-Item .env.example .env

# ============================================================================
# 1) Core Startup Settings (most users only need these)
# ============================================================================
HOST=127.0.0.1
PORT=3000

# Must be a 64-hex string (32 bytes)
# Example: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_random_64_hex

# Required only for gated Hugging Face repositories
HF_TOKEN=

# ============================================================================
# 2) Runtime Paths (optional)
# Use these to relocate runtime/db/projects/models/tools/logs/tmp/local.
# If unset, values are resolved from APP_RUNTIME_DIR (default: ./runtime).
# ============================================================================
# APP_RUNTIME_DIR=./runtime
# APP_DB_PATH=./runtime/db/db.json
# APP_PROJECTS_DIR=./runtime/projects
# APP_MODELS_DIR=./runtime/models
# APP_TOOLS_DIR=./runtime/tools
# APP_LOGS_DIR=./runtime/logs
# APP_TMP_DIR=./runtime/tmp
# APP_LOCAL_DIR=./runtime/local

# ============================================================================
# 3) HTTP Diagnostics & Slow Request Logging (optional)
# ============================================================================
# Max size for local uploaded media/subtitle files in bytes
# Default: 2147483648 (2 GiB)
# APP_UPLOAD_MAX_BYTES=2147483648

# Log timing for all HTTP requests (1=on, 0=off)
# APP_LOG_ALL_HTTP_TIMING=0

# /api/system/resources is polled frequently; keep muted unless debugging
# APP_LOG_SYSTEM_RESOURCES_POLLING=0

# Slow request threshold in milliseconds
# APP_HTTP_SLOW_MS=800

# Summary interval in seconds
# APP_HTTP_TIMING_SUMMARY_SEC=60

# Max top routes in summary
# APP_HTTP_TIMING_TOPN=8

# Max retained samples per route
# APP_HTTP_TIMING_SAMPLE_CAP=60

# ============================================================================
# 4) VAD Segmentation Parameters (speech chunking quality)
# ============================================================================
VAD_FRAME_SIZE=512
VAD_START_THRESHOLD=0.40
VAD_END_THRESHOLD=0.30
VAD_MIN_SPEECH_MS=500
VAD_MIN_SILENCE_MS=500
VAD_SILENCE_MODE=auto
VAD_FIXED_SILENCE_MS=800
VAD_PRE_SPEECH_MS=96
VAD_ADAPTIVE_MIN_SILENCE_MS=200
VAD_ADAPTIVE_MAX_SILENCE_MS=1800
VAD_PROGRESSIVE_TIER1_SEC=2
VAD_PROGRESSIVE_TIER2_SEC=4
VAD_PROGRESSIVE_TIER3_SEC=8
VAD_PAD_MS=120
VAD_MERGE_GAP_MS=250
VAD_LOG_STATS=0

# Optional OpenVINO IR/XML VAD model path (otherwise ONNX fallback is used)
# VAD_OPENVINO_MODEL_PATH=./runtime/models/silero_vad.xml

# ============================================================================
# 5) ASR Windowing & Large File Protection
# ============================================================================
VAD_TRANSCRIBE_MIN_SEGMENT_SEC=0.2
VAD_TRANSCRIBE_MERGE_GAP_SEC=0.30
VAD_TRANSCRIBE_MAX_WINDOW_SEC=120
VAD_TRANSCRIBE_MAX_WINDOWS=80
ASR_VAD_WINDOWING_ENABLED=1
ASR_VAD_SCHEDULER_ENABLED=1
ASR_VAD_RECONCILE_ENABLED=1
ASR_VAD_RECONCILE_OVERLAP_SEC=0.18
ASR_VAD_WINDOW_MAX_RETRIES=1
ASR_VAD_WINDOW_BATCH_SIZE_STABLE=1
ASR_VAD_WINDOW_BATCH_SIZE_THROUGHPUT=4
ASR_VAD_WINDOW_CONCURRENCY_STABLE=1
ASR_VAD_WINDOW_CONCURRENCY_THROUGHPUT=4

# Pipeline mode: stable | throughput
ASR_PIPELINE_MODE=stable
# Alignment strategy: alignment-first | provider-first
# ASR_ALIGNMENT_STRATEGY=alignment-first
# ASR decode policy (stable profile)
ASR_DECODE_TEMPERATURE_STABLE=0
ASR_DECODE_BEAM_SIZE_STABLE=1
ASR_DECODE_NO_SPEECH_STABLE=0.5
ASR_DECODE_CONDITION_ON_PREV_TEXT_STABLE=1
# ASR decode policy (throughput profile)
ASR_DECODE_TEMPERATURE_THROUGHPUT=0
ASR_DECODE_BEAM_SIZE_THROUGHPUT=1
ASR_DECODE_NO_SPEECH_THROUGHPUT=0.5
ASR_DECODE_CONDITION_ON_PREV_TEXT_THROUGHPUT=0

ASR_FILE_LIMIT_BYTES=26214400
ASR_FILE_LIMIT_CHUNK_SEC=480
ASR_FILE_LIMIT_MIN_CHUNK_SEC=60
ASR_FILE_LIMIT_MAX_CHUNKS=200
# Per-request timeout when calling cloud ASR providers (ms)
ASR_CLOUD_REQUEST_TIMEOUT_MS=120000

# ============================================================================
# 6) OpenVINO Runtime Controls (common)
# ============================================================================
# Helper launch mode (usually no need to change)
# OPENVINO_HELPER_USE_EXE=1
# If unset, deploy scripts may provision and configure an app-local Python automatically.
# OPENVINO_HELPER_PYTHON=python

# OpenVINO installation paths (set only when not auto-detected)
# OPENVINO_HELPER_INTEL_ROOT=C:/Program Files (x86)/Intel/openvino_2026
# INTEL_OPENVINO_DIR=C:/Program Files (x86)/Intel/openvino_2026
# OPENVINO_INSTALL_DIR=C:/Program Files (x86)/Intel/openvino_2026
# OPENVINO_DIR=C:/Program Files (x86)/Intel/openvino_2026/runtime
# OPENVINO_GENAI_DIR=C:/Program Files (x86)/Intel/openvino_2026/runtime
# Linux examples:
# OPENVINO_HELPER_INTEL_ROOT=/opt/intel/openvino_2026
# INTEL_OPENVINO_DIR=/opt/intel/openvino_2026
# OPENVINO_INSTALL_DIR=/opt/intel/openvino_2026
# OPENVINO_DIR=/opt/intel/openvino_2026/runtime
# OPENVINO_GENAI_DIR=/opt/intel/openvino_2026/runtime
# OPENVINO_LIB_PATHS=...
# Baseline OpenVINO utility models (VAD / speaker embedding / alignment) default to CPU for stability.
# Override only if this machine is confirmed stable with another OpenVINO device.
# OPENVINO_BASELINE_DEVICE=CPU

# Auto-convert Hugging Face models into OpenVINO INT8 when the repo is not already OV
# Set to 1 only if you want ArcSub to auto-install `optimum-intel[openvino]` when needed
# OPENVINO_HF_CONVERTER_AUTO_INSTALL_OPTIMUM=0

# Allow trust_remote_code for model/tokenizer export when the repo requires custom code
# OPENVINO_HF_EXPORT_TRUST_REMOTE_CODE=0

# Helper / runtime timeouts (milliseconds)
OPENVINO_ASR_LOAD_TIMEOUT_MS=180000
OPENVINO_ASR_TIMEOUT_MODE=auto
OPENVINO_ASR_TIMEOUT_MS=1800000
OPENVINO_ASR_TIMEOUT_MIN_MS=1800000
OPENVINO_ASR_TIMEOUT_MAX_MS=7200000
OPENVINO_ASR_TIMEOUT_BASE_MS=300000
OPENVINO_ASR_CPU_REALTIME_FACTOR=25
OPENVINO_ASR_GPU_REALTIME_FACTOR=8
OPENVINO_ASR_WORD_ALIGNMENT_TIMEOUT_MULTIPLIER=1.4
# In auto mode, the ASR timeout values above also drive helper transcribe requests.
# OPENVINO_HELPER_TRANSCRIBE_TIMEOUT_MS is the legacy/fixed helper fallback.
OPENVINO_STATUS_CACHE_MS=10000
OPENVINO_HELPER_HEALTH_TIMEOUT_MS=30000
OPENVINO_HELPER_LOAD_TIMEOUT_MS=180000
OPENVINO_HELPER_HEAVY_LOAD_TIMEOUT_MS=600000
OPENVINO_TRANSLATE_HELPER_LOAD_TIMEOUT_MS=180000
OPENVINO_TRANSLATE_HELPER_HEAVY_LOAD_TIMEOUT_MS=600000
OPENVINO_HELPER_TRANSCRIBE_TIMEOUT_MS=1800000
OPENVINO_HELPER_CONVERT_TIMEOUT_MS=7200000
OPENVINO_HELPER_UNLOAD_TIMEOUT_MS=15000
OPENVINO_HELPER_SHUTDOWN_TIMEOUT_MS=4000

# ============================================================================
# 7) OpenVINO ASR Device & Decode Tuning (advanced)
# ============================================================================
# Device target: AUTO / CPU / GPU / NPU (depends on runtime support)
# OPENVINO_LOCAL_ASR_DEVICE=AUTO

# Cache directory for local ASR pipeline
# OPENVINO_LOCAL_ASR_CACHE_DIR=./runtime/models/openvino-cache/asr

# Max decoded-audio cache items in memory
# OPENVINO_ASR_AUDIO_CACHE_MAX_ITEMS=12

# Language-specific decoding overrides are intentionally disabled.
# Local Whisper ASR now follows the same decoding path for every language unless
# a future language policy profile re-introduces a tested override.

# Qwen3-ASR official helper
# OPENVINO_QWEN3_ASR_MAX_BATCH_SIZE=1
# Stability cap for the official Qwen3-ASR helper when VAD windowing is off
# OPENVINO_QWEN3_ASR_MAX_CHUNK_SEC=120
# Optional conversion compression override for official Qwen3-ASR export: none | int8 | int4
# OPENVINO_QWEN3_ASR_CONVERSION_COMPRESSION_MODE=int8
# OPENVINO_QWEN3_ASR_MAX_NEW_TOKENS=256
# Qwen-only official forced aligner for native word timestamps
# OPENVINO_QWEN3_ASR_FORCED_ALIGNER_REPO=Qwen/Qwen3-ForcedAligner-0.6B
# OPENVINO_QWEN3_ASR_FORCED_ALIGNER_DEVICE=cpu
# OPENVINO_QWEN3_ASR_FORCED_ALIGNER_DTYPE=float32

# ============================================================================
# 8) OpenVINO Translation Runtime Tuning (advanced)
# ============================================================================
# Device target: AUTO / CPU / GPU / NPU (depends on runtime support)
# OPENVINO_LOCAL_TRANSLATE_DEVICE=AUTO

# Cache and throughput/latency hints
# OPENVINO_LOCAL_TRANSLATE_CACHE_DIR=./runtime/models/openvino-cache/translate
# OPENVINO_LOCAL_TRANSLATE_PERFORMANCE_HINT=LATENCY
# OPENVINO_LOCAL_TRANSLATE_NUM_STREAMS=1
# VLM runtime mode: auto/cached/isolated. auto keeps VLM models loaded and falls back to isolated on native state errors.
# OPENVINO_LOCAL_TRANSLATE_VLM_RUNTIME_MODE=auto

# Prompt lookup options
# OPENVINO_LOCAL_TRANSLATE_PROMPT_LOOKUP=0
# OPENVINO_LOCAL_TRANSLATE_PROMPT_LOOKUP_ASSISTANT_TOKENS=3
# OPENVINO_LOCAL_TRANSLATE_PROMPT_LOOKUP_MAX_NGRAM_SIZE=3
# OPENVINO_LOCAL_TRANSLATE_PROMPT_LOOKUP_CONFIDENCE=0

# Scheduler / token batching options
# OPENVINO_LOCAL_TRANSLATE_MAX_BATCHED_TOKENS=0
# OPENVINO_LOCAL_TRANSLATE_SCHEDULER_CACHE_SIZE_GB=0
# OPENVINO_LOCAL_TRANSLATE_DYNAMIC_SPLIT_FUSE=1

# Generation length and sampling.
# Leave these unset in normal use. ArcSub estimates max_new_tokens per batch from
# the selected model profile/runtime hints; setting these values is a global
# override for all local translation models.
# OPENVINO_LOCAL_TRANSLATE_MAX_NEW_TOKENS=2048
# OPENVINO_LOCAL_TRANSLATE_JSON_MAX_NEW_TOKENS=3072
# OPENVINO_LOCAL_TRANSLATE_ENABLE_SAMPLING=0

# ============================================================================
# 9) Model-family Specific Translation Sampling (usually keep defaults)
# ============================================================================
# Qwen3 family
# OPENVINO_LOCAL_TRANSLATE_QWEN3_TEMPERATURE=0.7
# OPENVINO_LOCAL_TRANSLATE_QWEN3_STRICT_TEMPERATURE=0.3
# OPENVINO_LOCAL_TRANSLATE_QWEN3_TOP_P=0.8
# OPENVINO_LOCAL_TRANSLATE_QWEN3_TOP_K=20
# OPENVINO_LOCAL_TRANSLATE_QWEN3_MIN_P=0
# OPENVINO_LOCAL_TRANSLATE_QWEN3_PRESENCE_PENALTY=0

# DeepSeek R1 family
# OPENVINO_LOCAL_TRANSLATE_DEEPSEEK_R1_TEMPERATURE=0.7
# OPENVINO_LOCAL_TRANSLATE_DEEPSEEK_R1_STRICT_TEMPERATURE=0.3
# OPENVINO_LOCAL_TRANSLATE_DEEPSEEK_R1_TOP_P=0.95
# OPENVINO_LOCAL_TRANSLATE_DEEPSEEK_R1_TOP_K=50
# OPENVINO_LOCAL_TRANSLATE_DEEPSEEK_R1_MIN_P=0

# ============================================================================
# 10) Translation Pipeline Batching & Retry (advanced)
# ============================================================================
# Local translation batching.
# Leave this section unset in normal use. Exact model profiles and HF/runtime
# hints provide the default batch caps; these variables are manual overrides for
# benchmarking, low-memory devices, or compatibility fallback.
# TRANSLATE_LOCAL_BATCHING_MODE=auto
#   auto: use model-specific token-aware batching when HF/runtime hints are available
#   token_aware: force tokenizer-aware batching for all local translation models
#   fixed_lines: force legacy line/char-budget batching
# TRANSLATE_LOCAL_INPUT_TOKEN_BUDGET=0
#   0: derive from the selected model context/output token hints
# TRANSLATE_LOCAL_BATCH_SIZE=60
# TRANSLATE_LOCAL_BATCH_CHAR_BUDGET=5000
# TRANSLATE_LOCAL_ALLOW_PROFILE_CAP_OVERRIDE=0
#   1: allow the env line/char caps above to exceed exact model profile caps

# TranslateGemma dedicated batching overrides.
# Leave unset unless you are benchmarking TranslateGemma specifically. The model
# uses its official source/target/text template, so these caps only affect how
# ArcSub groups subtitle rows before sending them to TranslateGemma.
# TRANSLATEGEMMA_BATCHING_MODE=token_aware
#   token_aware: tokenize-aware batching (slower pre-processing, safer token fit)
#   fixed_lines: line/char-budget batching only (faster pre-processing, less token-aware)
# TRANSLATEGEMMA_INPUT_TOKEN_BUDGET=960

# TRANSLATE_LOCAL_JSON_REPAIR_MAX_LINES_BEFORE_SPLIT=32
# TRANSLATE_LOCAL_RESIDUAL_RETRY_LIMIT=8

# JSON repair batching
# TRANSLATE_JSON_REPAIR_BATCH_SIZE=80

# Cloud translation batching and retries
# TRANSLATE_REMOTE_BATCH_SIZE=60
# TRANSLATE_MAX_RETRIES=2
# TRANSLATE_RETRY_BASE_MS=800
# TRANSLATE_RATE_LIMIT_RETRY_MS=12000

# ============================================================================
# 11) Cloud Translation Context Mode (LLM APIs)
# ============================================================================
# TRANSLATE_CLOUD_CONTEXT_MODE=0
# TRANSLATE_CLOUD_CONTEXT_TARGET_LINES=24
# TRANSLATE_CLOUD_CONTEXT_MIN_TARGET_LINES=6
# TRANSLATE_CLOUD_CONTEXT_WINDOW=2
# TRANSLATE_CLOUD_CONTEXT_CHAR_BUDGET=2400
# TRANSLATE_CLOUD_CONTEXT_MAX_SPLIT_DEPTH=2
